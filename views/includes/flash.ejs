<%
const successMsgs = Array.isArray(success) ? success : success ? [success] : [];
const errorMsgs = Array.isArray(error) ? error : error ? [error] : [];
const welcomeMsgs = showWelcomeMessage && welcomeMessage ? [welcomeMessage] : [];
const allSuccess = [...welcomeMsgs, ...successMsgs];
%>
<div class="fixed left-1/2 top-20 z-[60] w-[92%] max-w-xl -translate-x-1/2 space-y-2">
  <% allSuccess.forEach(function(msg) { %>
  <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-soft"><%= msg %></div>
  <% }) %>
  <% errorMsgs.forEach(function(msg) { %>
  <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800 shadow-soft"><%= msg %></div>
  <% }) %>
</div>
