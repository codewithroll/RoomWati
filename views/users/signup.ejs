<%- layout("/layouts/boilerplate") %>
<section class="mx-auto max-w-md rounded-2xl bg-white p-6 shadow-soft sm:p-8">
  <h1 class="text-2xl font-bold">Sign Up</h1>
  <p class="mt-2 text-sm text-slate-600">Create your account to start browsing listings.</p>
  <form action="/signup" method="post" class="needs-validation mt-6 space-y-4" novalidate>
    <div><label class="mb-1 block text-sm font-semibold">Username</label><input type="text" name="username" id="username" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
    <div><label class="mb-1 block text-sm font-semibold">Email</label><input type="email" name="email" id="email" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
    <div>
      <label class="mb-1 block text-sm font-semibold">Password</label>
      <div class="relative form-group">
        <input type="password" name="password" id="password" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5 pr-12" />
        <button type="button" class="password-toggle absolute right-3 top-1/2 -translate-y-1/2 text-slate-500"><i class="fa-regular fa-eye"></i></button>
      </div>
    </div>
    <button type="submit" class="w-full rounded-xl bg-rose-600 px-5 py-3 text-sm font-semibold text-white hover:bg-rose-700">Create Account</button>
  </form>
  <div class="mt-5 space-y-2">
    <button type="button" class="w-full rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-slate-50" onclick="window.location.href='/auth/google'">Continue with Google</button>
    <button type="button" class="w-full rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium hover:bg-slate-50" onclick="window.location.href='/auth/facebook'">Continue with Facebook</button>
  </div>
  <p class="mt-5 text-center text-sm text-slate-600">Already have an account? <a href="/login" class="font-semibold text-rose-700">Log in</a></p>
</section>
