<%- layout("/layouts/boilerplate") %>
<section class="space-y-6">
  <header class="overflow-hidden rounded-2xl bg-white shadow-soft">
    <img src="<%= user.coverImage.url %>" alt="Cover" class="h-40 w-full object-cover sm:h-52" />
    <div class="-mt-10 flex flex-col gap-4 px-6 pb-6 sm:flex-row sm:items-end">
      <img src="<%= user.image.url %>" alt="<%= user.username %>" class="h-20 w-20 rounded-full border-4 border-white object-cover" />
      <div class="flex-1">
        <h1 class="text-2xl font-bold"><%= user.username %></h1>
        <p class="mt-1 text-sm text-slate-600"><%= user.email %></p>
        <p class="mt-2 text-sm text-slate-500"><%= user.bio %></p>
      </div>
      <a href="/profile/edit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold">Edit Profile</a>
    </div>
  </header>

  <div class="rounded-2xl bg-white p-3 shadow-soft">
    <div class="grid grid-cols-3 gap-2">
      <button class="user-nav-btn active rounded-xl bg-rose-600 px-3 py-2 text-sm font-semibold text-white" data-tab="listings"><i class="fas fa-home mr-1"></i>My Listings <span class="count"><%= userListings.length %></span></button>
      <button class="user-nav-btn rounded-xl border border-slate-300 px-3 py-2 text-sm font-semibold" data-tab="favorites"><i class="fas fa-heart mr-1"></i>Favorites <span class="count"><%= favoriteListings.length %></span></button>
      <button class="user-nav-btn rounded-xl border border-slate-300 px-3 py-2 text-sm font-semibold" data-tab="analytics"><i class="fas fa-chart-line mr-1"></i>Analytics</button>
    </div>
  </div>

  <div class="user-tab-content active" id="listings-tab">
    <% if (userListings.length === 0) { %>
    <div class="rounded-2xl bg-white p-10 text-center shadow-soft">
      <h3 class="text-lg font-semibold">No Listings Yet</h3>
      <a href="/listings/new" class="mt-4 inline-flex rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white">Create Listing</a>
    </div>
    <% } else { %>
    <div class="grid gap-4 md:grid-cols-2">
      <% userListings.forEach(listing => { %>
      <article class="user-listing-card overflow-hidden rounded-2xl bg-white shadow-soft" data-views="<%= listing.viewCount || 0 %>" data-favorites="<%= listing.favoriteCount || 0 %>" data-price="<%= listing.price %>">
        <div class="relative">
          <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="h-48 w-full object-cover" />
          <div class="user-listing-price absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold">?<%= listing.price.toLocaleString("en-IN") %>/month</div>
        </div>
        <div class="user-listing-info p-4">
          <h3 class="listing-title text-base font-semibold"><%= listing.title %></h3>
          <p class="mt-1 text-sm text-slate-500"><i class="fas fa-map-marker-alt mr-1"></i><%= listing.location %></p>
          <div class="user-listing-stats mt-3 flex gap-3 text-xs text-slate-600">
            <span class="view-count"><i class="fas fa-eye mr-1"></i><%= listing.viewCount || 0 %></span>
            <span class="favorite-count"><i class="fas fa-heart mr-1"></i><%= listing.favoriteCount || 0 %></span>
          </div>
          <div class="mt-4 flex gap-2">
            <a href="/listings/<%= listing._id %>" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold">View</a>
            <a href="/listings/<%= listing._id %>/edit" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold">Edit</a>
          </div>
        </div>
      </article>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="user-tab-content hidden" id="favorites-tab">
    <% if (favoriteListings.length === 0) { %>
    <div class="rounded-2xl bg-white p-10 text-center shadow-soft"><h3 class="text-lg font-semibold">No Favorites Yet</h3><a href="/listings" class="mt-4 inline-flex rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white">Browse Listings</a></div>
    <% } else { %>
    <div class="grid gap-4 md:grid-cols-2">
      <% favoriteListings.forEach(listing => { %>
      <article class="user-listing-card overflow-hidden rounded-2xl bg-white shadow-soft">
        <div class="relative">
          <a href="/listings/<%= listing._id %>"><img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="h-48 w-full object-cover" /></a>
          <button class="favorite-btn active absolute right-3 top-3 rounded-full bg-white/90 p-2" data-listing-id="<%= listing._id %>" title="Remove from favorites" aria-label="Remove from favorites"><i class="fas fa-heart text-rose-600"></i></button>
        </div>
        <div class="user-listing-info p-4">
          <h3 class="listing-title text-base font-semibold"><%= listing.title %></h3>
          <p class="mt-1 text-sm text-slate-500"><%= listing.location %>, <%= listing.country || 'India' %></p>
          <div class="user-listing-stats mt-3 flex gap-3 text-xs text-slate-600">
            <span class="view-count"><i class="fas fa-eye mr-1"></i><%= listing.viewCount || 0 %></span>
            <span class="favorite-count"><i class="fas fa-heart mr-1"></i><%= listing.favoriteCount || 0 %></span>
          </div>
          <a href="/listings/<%= listing._id %>" class="mt-4 inline-flex rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold">View</a>
        </div>
      </article>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="user-tab-content hidden" id="analytics-tab">
    <div class="analytics-dashboard-content space-y-4">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-xl font-bold">Listing Analytics</h2>
        <div class="flex gap-2">
          <button class="time-period-btn active rounded-lg border border-slate-300 px-3 py-1.5 text-xs" data-days="7">7D</button>
          <button class="time-period-btn rounded-lg border border-slate-300 px-3 py-1.5 text-xs" data-days="30">30D</button>
          <button class="time-period-btn rounded-lg border border-slate-300 px-3 py-1.5 text-xs" data-days="90">90D</button>
          <button class="refresh-analytics rounded-lg bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white">Refresh</button>
        </div>
      </div>

      <div class="analytics-loading hidden rounded-xl border border-slate-200 bg-white p-4 text-sm">Loading analytics...</div>
      <div class="analytics-error hidden rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-700"></div>
      <div class="analytics-empty-state hidden rounded-xl border border-slate-200 bg-white p-6 text-sm">No analytics data available.</div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <article class="summary-card rounded-xl border border-slate-200 bg-white p-4"><h3 class="text-xs uppercase tracking-wide text-slate-500">Total Listings</h3><p class="summary-value mt-2 text-2xl font-bold"><%= stats.totalListings || userListings.length %></p><p class="summary-change mt-1 text-xs text-slate-500">Updated now</p></article>
        <article class="summary-card rounded-xl border border-slate-200 bg-white p-4"><h3 class="text-xs uppercase tracking-wide text-slate-500">Total Views</h3><p class="summary-value mt-2 text-2xl font-bold"><%= stats.totalViews || 0 %></p><p class="summary-change mt-1 text-xs text-slate-500">Updated now</p></article>
        <article class="summary-card rounded-xl border border-slate-200 bg-white p-4"><h3 class="text-xs uppercase tracking-wide text-slate-500">Total Favorites</h3><p class="summary-value mt-2 text-2xl font-bold"><%= stats.totalFavorites || 0 %></p><p class="summary-change mt-1 text-xs text-slate-500">Updated now</p></article>
        <article class="summary-card rounded-xl border border-slate-200 bg-white p-4"><h3 class="text-xs uppercase tracking-wide text-slate-500">Average Rating</h3><p class="summary-value mt-2 text-2xl font-bold">0.0</p><p class="stars mt-1 text-amber-500">?????</p><p class="total-reviews mt-1 text-xs text-slate-500">0 reviews</p></article>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <article class="chart-card rounded-2xl bg-white p-4 shadow-soft"><h3 class="mb-3 text-sm font-semibold">Performance</h3><canvas id="performanceChart" height="220"></canvas></article>
        <article class="chart-card rounded-2xl bg-white p-4 shadow-soft"><h3 class="mb-3 text-sm font-semibold">Top Listings</h3><canvas id="listingsChart" height="220"></canvas></article>
        <article class="chart-card rounded-2xl bg-white p-4 shadow-soft"><h3 class="mb-3 text-sm font-semibold">Engagement</h3><canvas id="engagementChart" height="220"></canvas></article>
        <article class="chart-card rounded-2xl bg-white p-4 shadow-soft"><h3 class="mb-3 text-sm font-semibold">Ratings</h3><canvas id="ratingsChart" height="220"></canvas></article>
      </div>

      <p class="last-updated-time text-xs text-slate-500" data-last-updated>Last updated just now</p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navBtns = document.querySelectorAll('.user-nav-btn');
    const tabContents = document.querySelectorAll('.user-tab-content');
    navBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        navBtns.forEach((b) => { b.classList.remove('active', 'bg-rose-600', 'text-white'); b.classList.add('border', 'border-slate-300'); });
        btn.classList.add('active', 'bg-rose-600', 'text-white');
        tabContents.forEach((tab) => tab.classList.add('hidden'));
        const tab = document.getElementById(btn.dataset.tab + '-tab');
        tab?.classList.remove('hidden');
      });
    });

    document.addEventListener('click', async (e) => {
      const favoriteBtn = e.target.closest('.favorite-btn');
      if (!favoriteBtn) return;
      e.preventDefault();
      const listingId = favoriteBtn.dataset.listingId;
      try {
        const res = await fetch(`/toggle-favorite/${listingId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' });
        const data = await res.json();
        if (!res.ok) return;
        const card = favoriteBtn.closest('.user-listing-card');
        if (data.status === 'removed') card?.remove();
      } catch {}
    });
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
<script src="/js/analytics.js"></script>
