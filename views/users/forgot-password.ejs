<%- layout("/layouts/boilerplate") %>
<section class="mx-auto max-w-md rounded-2xl bg-white p-6 shadow-soft sm:p-8">
  <h1 class="text-2xl font-bold">Forgot Password</h1>
  <p class="mt-2 text-sm text-slate-600">We will send a verification code to your email.</p>

  <div class="forgot-password-form mt-6">
    <form id="forgotPasswordForm" class="space-y-4">
      <div>
        <label for="email" class="mb-1 block text-sm font-semibold">Email Address</label>
        <input type="email" name="email" id="email" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
      </div>
      <div id="errorMessage" class="hidden rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
      <div id="successMessage" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700"></div>
      <button type="submit" class="w-full rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">
        <span id="submitSpinner" class="hidden">...</span>
        <span id="submitButtonText">Send Verification Code</span>
      </button>
      <a href="/login" class="block text-center text-sm font-medium text-slate-600">Back to Login</a>
    </form>
  </div>

  <div class="verify-otp-form hidden mt-6">
    <form id="verifyOtpForm" class="space-y-4">
      <label for="otp" class="mb-1 block text-sm font-semibold">Verification Code</label>
      <input type="text" name="otp" id="otp" maxlength="6" pattern="\d{6}" inputmode="numeric" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-center tracking-[0.35em]" />
      <button type="button" id="resendOtp" class="text-sm font-semibold text-rose-700">Resend Code</button>
      <button type="submit" class="w-full rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white">Verify Code</button>
    </form>
  </div>

  <div class="reset-password-form hidden mt-6">
    <form id="resetPasswordForm" class="space-y-4">
      <input type="hidden" id="resetToken" name="resetToken" value="" />
      <div>
        <label for="password" class="mb-1 block text-sm font-semibold">New Password</label>
        <div class="relative">
          <input type="password" name="password" id="password" minlength="8" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5 pr-12" />
          <button type="button" class="password-toggle absolute right-3 top-1/2 -translate-y-1/2 text-slate-500" data-target="password"><i class="fa-regular fa-eye"></i></button>
        </div>
      </div>
      <div>
        <label for="confirmPassword" class="mb-1 block text-sm font-semibold">Confirm Password</label>
        <div class="relative">
          <input type="password" name="confirmPassword" id="confirmPassword" minlength="8" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5 pr-12" />
          <button type="button" class="password-toggle absolute right-3 top-1/2 -translate-y-1/2 text-slate-500" data-target="confirmPassword"><i class="fa-regular fa-eye"></i></button>
        </div>
      </div>
      <button type="submit" class="w-full rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white" data-text="Reset Password"><span id="resetSpinner" class="hidden">...</span> <span>Reset Password</span></button>
    </form>
  </div>
</section>

<script src="/js/email-service.js"></script>
<script src="/js/forgot-password.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.password-toggle').forEach(button => {
      button.addEventListener('click', function() {
        const targetId = this.getAttribute('data-target');
        const input = document.getElementById(targetId);
        const icon = this.querySelector('i');
        if (!input) return;
        if (input.type === 'password') { input.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
        else { input.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
      });
    });
  });
</script>
