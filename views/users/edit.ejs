<%- include("../includes/flash") %>
<% layout("/layouts/boilerplate") %>

<section class="mx-auto max-w-3xl space-y-6 rounded-2xl bg-white p-6 shadow-soft sm:p-8">
  <header>
    <h1 class="text-2xl font-bold">Edit Profile</h1>
    <p class="mt-1 text-sm text-slate-600">Update your basic details and profile images.</p>
  </header>

  <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" class="space-y-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="space-y-2">
        <img src="<%= user.coverImage.url %>" alt="Cover Image Preview" id="coverPreview" class="h-40 w-full rounded-xl object-cover" />
        <label for="coverImage" class="block text-sm font-semibold">Cover Image</label>
        <input type="file" id="coverImage" name="coverImage" accept="image/*" class="w-full rounded-xl border border-slate-300 px-3 py-2" />
      </div>
      <div class="space-y-2">
        <img src="<%= user.image.url %>" alt="Profile Image Preview" id="profilePreview" class="h-40 w-full rounded-xl object-cover" />
        <label for="profileImage" class="block text-sm font-semibold">Profile Image</label>
        <input type="file" id="profileImage" name="profileImage" accept="image/*" class="w-full rounded-xl border border-slate-300 px-3 py-2" />
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="username" class="mb-1 block text-sm font-semibold">Username</label>
        <input type="text" id="username" name="username" value="<%= user.username %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-semibold">Email</label>
        <input type="email" id="email" name="email" value="<%= user.email %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
      </div>
    </div>

    <div>
      <label for="bio" class="mb-1 block text-sm font-semibold">Bio</label>
      <textarea id="bio" name="bio" maxlength="200" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" rows="4"><%= user.bio %></textarea>
      <p class="mt-1 text-xs text-slate-500"><span id="bioCharCount">0</span>/200 characters</p>
    </div>

    <div class="flex items-center justify-between">
      <a href="/profile" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold">Cancel</a>
      <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700">Save Changes</button>
    </div>
  </form>
</section>

<script>
  function previewImage(input, previewId) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function (e) {
        const previewImage = document.getElementById(previewId);
        previewImage.src = e.target.result;
        if (previewId === "profilePreview") {
          const navbarImage = document.getElementById("navbar-profile-image");
          if (navbarImage) navbarImage.src = e.target.result;
        }
      };
      reader.readAsDataURL(input.files[0]);
    }
  }

  document.getElementById("profileImage")?.addEventListener("change", function () { previewImage(this, "profilePreview"); });
  document.getElementById("coverImage")?.addEventListener("change", function () { previewImage(this, "coverPreview"); });

  const bioInput = document.getElementById("bio");
  const bioCharCount = document.getElementById("bioCharCount");
  function updateCharCount() { if (!bioInput || !bioCharCount) return; bioCharCount.textContent = bioInput.value.length; }
  bioInput?.addEventListener("input", updateCharCount);
  updateCharCount();
</script>
