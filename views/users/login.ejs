<%- layout("/layouts/boilerplate") %>
<section class="mx-auto max-w-xl rounded-2xl bg-white p-6 shadow-soft sm:p-8">
  <h1 class="text-2xl font-bold">Log In</h1>
  <p class="mt-2 text-sm text-slate-600">Use password or OTP login.</p>

  <div class="mt-6 flex rounded-xl bg-slate-100 p-1 text-sm">
    <button id="password-tab" class="flex-1 rounded-lg bg-white px-3 py-2 font-semibold">Password</button>
    <button id="otp-tab" class="flex-1 rounded-lg px-3 py-2 font-semibold text-slate-600">OTP</button>
  </div>

  <div id="password-tab-pane" class="mt-5">
    <form id="passwordLoginForm" class="needs-validation space-y-4" novalidate>
      <div><label class="mb-1 block text-sm font-semibold">Username or Email</label><input type="text" name="username" id="username" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
      <div class="form-group">
        <label class="mb-1 block text-sm font-semibold">Password</label>
        <div class="relative">
          <input type="password" name="password" id="password" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5 pr-12" />
          <button type="button" class="password-toggle absolute right-3 top-1/2 -translate-y-1/2 text-slate-500" data-target="password"><i class="fa-regular fa-eye"></i></button>
        </div>
        <a href="/forgot-password" class="mt-1 inline-block text-xs font-medium text-rose-700">Forgot password?</a>
      </div>
      <div id="passwordError" class="hidden rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
      <button type="submit" class="w-full rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700"><span id="passwordSpinner" class="hidden">...</span> <span id="passwordButtonText">Log in</span></button>
    </form>
  </div>

  <div id="otp-tab-pane" class="mt-5 hidden">
    <form id="otpLoginForm" class="space-y-4">
      <div><label class="mb-1 block text-sm font-semibold">Email</label><input type="email" name="email" id="email" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
      <div id="otpFields" class="hidden">
        <label class="mb-1 block text-sm font-semibold">OTP</label>
        <input type="text" name="otp" id="otp" maxlength="6" pattern="\d{6}" inputmode="numeric" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-center tracking-[0.4em]" />
        <div class="mt-2 text-xs"><a href="#" id="resendOtp" class="text-rose-700">Resend Code</a> <span id="resendTimer" class="text-slate-500"></span></div>
      </div>
      <div id="otpError" class="hidden rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
      <div id="otpSuccess" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700"></div>
      <button type="button" id="sendOtpBtn" class="w-full rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white">Send Verification Code</button>
      <button type="submit" id="verifyOtpBtn" class="hidden w-full rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white"><span id="otpVerifySpinner" class="hidden">...</span> <span id="otpVerifyButtonText">Verify & Login</span></button>
    </form>
  </div>

  <p class="mt-5 text-center text-sm text-slate-600">Don't have an account? <a href="/signup" class="font-semibold text-rose-700">Sign up</a></p>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const passwordTabBtn = document.getElementById("password-tab");
    const otpTabBtn = document.getElementById("otp-tab");
    const passwordPane = document.getElementById("password-tab-pane");
    const otpPane = document.getElementById("otp-tab-pane");
    passwordTabBtn.addEventListener("click", () => { passwordPane.classList.remove("hidden"); otpPane.classList.add("hidden"); passwordTabBtn.classList.add("bg-white"); otpTabBtn.classList.remove("bg-white"); });
    otpTabBtn.addEventListener("click", () => { otpPane.classList.remove("hidden"); passwordPane.classList.add("hidden"); otpTabBtn.classList.add("bg-white"); passwordTabBtn.classList.remove("bg-white"); });

    const passwordLoginForm = document.getElementById("passwordLoginForm");
    const passwordButtonText = document.getElementById("passwordButtonText");
    const passwordError = document.getElementById("passwordError");
    const otpLoginForm = document.getElementById("otpLoginForm");
    const otpFields = document.getElementById("otpFields");
    const otpInput = document.getElementById("otp");
    const sendOtpBtn = document.getElementById("sendOtpBtn");
    const verifyOtpBtn = document.getElementById("verifyOtpBtn");
    const otpError = document.getElementById("otpError");
    const otpSuccess = document.getElementById("otpSuccess");
    const resendOtpLink = document.getElementById("resendOtp");
    const resendTimer = document.getElementById("resendTimer");
    const otpVerifyButtonText = document.getElementById("otpVerifyButtonText");

    let countdown = 0; let countdownInterval;
    function showPasswordError(m){ passwordError.textContent=m; passwordError.classList.remove("hidden"); }
    function showOtpError(m){ otpError.textContent=m; otpError.classList.remove("hidden"); otpSuccess.classList.add("hidden"); }
    function showOtpSuccess(m){ otpSuccess.textContent=m; otpSuccess.classList.remove("hidden"); otpError.classList.add("hidden"); }
    function startResendTimer(){ clearInterval(countdownInterval); countdown=120; updateResendButton(); countdownInterval=setInterval(()=>{countdown--; updateResendButton(); if(countdown<=0) clearInterval(countdownInterval);},1000); }
    function updateResendButton(){ if(countdown>0){ const min=Math.floor(countdown/60), sec=countdown%60; resendOtpLink.style.pointerEvents='none'; resendOtpLink.classList.add('opacity-50'); resendTimer.textContent=`(${min}:${String(sec).padStart(2,'0')})`; } else { resendOtpLink.style.pointerEvents='auto'; resendOtpLink.classList.remove('opacity-50'); resendTimer.textContent=''; } }

    passwordLoginForm?.addEventListener("submit", async function (e) {
      e.preventDefault();
      const formData = new FormData(passwordLoginForm);
      passwordButtonText.textContent = "Logging in..."; passwordError.classList.add("hidden");
      try {
        const response = await fetch("/login", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ username: String(formData.get("username")||"").trim(), password: String(formData.get("password")||"") }), credentials:"same-origin" });
        const result = await response.json();
        if (!response.ok || !result.success) return showPasswordError(result.message || "Invalid username or password");
        window.location.href = result.redirectUrl || "/listings";
      } catch { showPasswordError("An error occurred. Please try again."); }
      finally { passwordButtonText.textContent = "Log in"; }
    });

    sendOtpBtn?.addEventListener("click", async function (e) {
      e.preventDefault(); const emailInput = document.getElementById("email"); const email = emailInput.value.trim();
      if (!email) return showOtpError("Please enter your email address");
      sendOtpBtn.disabled = true; sendOtpBtn.textContent = "Sending...";
      try {
        const response = await fetch("/auth/login-with-otp", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ email }) });
        const data = await response.json();
        if (!data.success) return showOtpError(data.message || "Failed to send OTP");
        otpFields.classList.remove("hidden"); sendOtpBtn.classList.add("hidden"); verifyOtpBtn.classList.remove("hidden"); startResendTimer(); showOtpSuccess("OTP sent to your email"); otpInput?.focus();
      } catch { showOtpError("Failed to send OTP. Please try again."); }
      finally { sendOtpBtn.disabled = false; sendOtpBtn.textContent = "Send Verification Code"; }
    });

    otpLoginForm?.addEventListener("submit", async function (e) {
      e.preventDefault(); if (verifyOtpBtn.classList.contains("hidden") || verifyOtpBtn.disabled) return;
      const email = document.getElementById("email").value.trim(); const otpCode = otpInput.value.trim();
      if (!otpCode) return showOtpError("Please enter the OTP");
      verifyOtpBtn.disabled = true; otpVerifyButtonText.textContent = "Verifying...";
      try {
        const response = await fetch("/auth/verify-login-otp", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ email, otp: otpCode }) });
        const data = await response.json();
        if (!data.success) { showOtpError(data.message || "Invalid OTP"); otpInput.value=""; otpInput.focus(); return; }
        showOtpSuccess("Login successful! Redirecting..."); setTimeout(()=>window.location.href = data.redirectUrl || "/listings", 1200);
      } catch { showOtpError("Verification failed."); }
      finally { verifyOtpBtn.disabled = false; otpVerifyButtonText.textContent = "Verify & Login"; }
    });

    resendOtpLink?.addEventListener("click", async function (e) {
      e.preventDefault(); if (countdown > 0) return;
      const email = document.getElementById("email").value.trim();
      try {
        const response = await fetch("/auth/resend-otp", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ email, purpose: "login" }) });
        const result = await response.json(); if (!result.success) return showOtpError(result.message || "Failed to resend OTP");
        startResendTimer(); showOtpSuccess("New verification code sent");
      } catch { showOtpError("Failed to resend OTP."); }
    });

    document.querySelectorAll(".password-toggle").forEach((button) => {
      button.addEventListener("click", function () {
        const targetId = this.getAttribute("data-target") || "password";
        const input = document.getElementById(targetId); const icon = this.querySelector("i");
        if (input.type === "password") { input.type = "text"; icon.classList.replace("fa-eye", "fa-eye-slash"); }
        else { input.type = "password"; icon.classList.replace("fa-eye-slash", "fa-eye"); }
      });
    });

    otpInput?.addEventListener("input", function () { this.value = this.value.replace(/[^0-9]/g, ""); });
  });
</script>
