<% layout("/layouts/boilerplate") %>
<section class="mx-auto max-w-4xl rounded-2xl bg-white p-6 shadow-soft sm:p-8">
  <h1 class="text-2xl font-bold text-slate-900">Edit Listing</h1>
  <form method="post" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data" class="needs-validation mt-6 space-y-5" novalidate>
    <div>
      <label class="mb-1 block text-sm font-semibold">Title</label>
      <input type="text" name="listing[title]" value="<%= listing.title %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
    </div>
    <div>
      <label class="mb-1 block text-sm font-semibold">Description</label>
      <textarea name="listing[description]" rows="4" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5"><%= listing.description %></textarea>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div><label class="mb-1 block text-sm font-semibold">Price</label><input type="number" name="listing[price]" value="<%= listing.price %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
      <div><label class="mb-1 block text-sm font-semibold">Country</label><input type="text" name="listing[country]" value="<%= listing.country %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" /></div>
    </div>
    <div>
      <label class="mb-1 block text-sm font-semibold">Location</label>
      <input type="text" name="listing[location]" value="<%= listing.location %>" required class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
    </div>
    <div class="rounded-xl border border-slate-200 p-4">
      <p class="mb-2 text-sm font-semibold">Current Image</p>
      <img src="<%= originalImageUrl %>" alt="Current Image" class="h-40 w-full rounded-lg object-cover" />
      <input type="file" id="image" name="listing[image]" accept="image/*" class="mt-3 w-full rounded-xl border border-slate-300 px-4 py-2" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <select name="listing[roomType]" class="w-full rounded-xl border border-slate-300 px-4 py-2.5">
        <option value="single" <%= listing.roomType === 'single' ? 'selected' : '' %>>Single</option>
        <option value="shared" <%= listing.roomType === 'shared' ? 'selected' : '' %>>Shared</option>
        <option value="studio" <%= listing.roomType === 'studio' ? 'selected' : '' %>>Studio</option>
        <option value="ensuite" <%= listing.roomType === 'ensuite' ? 'selected' : '' %>>Ensuite</option>
      </select>
      <select name="listing[furnished]" class="w-full rounded-xl border border-slate-300 px-4 py-2.5">
        <option value="furnished" <%= listing.furnished === 'furnished' ? 'selected' : '' %>>Furnished</option>
        <option value="unfurnished" <%= listing.furnished === 'unfurnished' ? 'selected' : '' %>>Unfurnished</option>
        <option value="semifurnished" <%= listing.furnished === 'semifurnished' ? 'selected' : '' %>>Semi-Furnished</option>
      </select>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <select name="listing[genderPreference]" class="w-full rounded-xl border border-slate-300 px-4 py-2.5">
        <option value="any" <%= listing.genderPreference === 'any' ? 'selected' : '' %>>Any</option>
        <option value="male" <%= listing.genderPreference === 'male' ? 'selected' : '' %>>Male</option>
        <option value="female" <%= listing.genderPreference === 'female' ? 'selected' : '' %>>Female</option>
      </select>
      <select name="listing[preferredTenants]" class="w-full rounded-xl border border-slate-300 px-4 py-2.5">
        <option value="any" <%= listing.preferredTenants === 'any' ? 'selected' : '' %>>Any</option>
        <option value="students" <%= listing.preferredTenants === 'students' ? 'selected' : '' %>>Students</option>
        <option value="professionals" <%= listing.preferredTenants === 'professionals' ? 'selected' : '' %>>Professionals</option>
        <option value="family" <%= listing.preferredTenants === 'family' ? 'selected' : '' %>>Family</option>
        <option value="couples" <%= listing.preferredTenants === 'couples' ? 'selected' : '' %>>Couples</option>
      </select>
    </div>

    <div class="grid gap-3 text-sm sm:grid-cols-2">
      <label><input type="checkbox" name="listing[immediateAvailability]" <%= listing.immediateAvailability ? 'checked' : '' %> class="mr-2" />Immediate Availability</label>
      <input type="date" name="listing[availableFrom]" value="<%= listing.availableFrom ? listing.availableFrom.toISOString().split('T')[0] : '' %>" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <input type="number" name="listing[securityDeposit]" value="<%= listing.securityDeposit || '' %>" placeholder="Security Deposit" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
      <input type="number" name="listing[minStayMonths]" value="<%= listing.minStayMonths || '' %>" placeholder="Minimum Stay" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <input type="text" name="listing[rules][curfewDetails]" value="<%= listing.rules && listing.rules.curfewDetails ? listing.rules.curfewDetails : '' %>" placeholder="Curfew details" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
      <input type="text" name="listing[bills][details]" value="<%= listing.bills && listing.bills.details ? listing.bills.details : '' %>" placeholder="Bill details" class="w-full rounded-xl border border-slate-300 px-4 py-2.5" />
    </div>

    <div class="flex items-center justify-between">
      <a href="/listings/<%= listing._id %>" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium">Cancel</a>
      <button type="submit" class="rounded-xl bg-rose-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Save Changes</button>
    </div>
  </form>
</section>
