<% layout("/layouts/boilerplate", { listing: listing }) %>
<section class="space-y-6">
  <header class="rounded-2xl bg-white p-6 shadow-soft">
    <h1 class="text-2xl font-bold"><%= listing.title %></h1>
    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-slate-600">
      <span class="listing-rating"><i class="fas fa-star text-amber-500"></i>
        <% if(listing.reviews.length > 0) { let avgRating = 0; listing.reviews.forEach(review => { avgRating += review.rating }); avgRating = (avgRating / listing.reviews.length).toFixed(1); %>
        <span><%= avgRating %></span>
        <% } else { %><span>New</span><% } %>
      </span>
      <span><%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %></span>
      <span><i class="fas fa-eye"></i> <span class="view-count"><%= listing.viewCount || 0 %></span> views</span>
      <span><i class="fas fa-heart"></i> <span class="favorite-count" data-initial-favorite-count="<%= Math.max(0, listing.favoriteCount || 0) %>" data-listing-id="<%= listing._id %>"><%= Math.max(0, listing.favoriteCount || 0) %></span> favorites</span>
      <span><i class="fas fa-map-marker-alt"></i> <%= listing.location %>, <%= listing.country %></span>
    </div>
  </header>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="space-y-6 lg:col-span-2">
      <div class="image-carousel relative overflow-hidden rounded-2xl bg-white shadow-soft">
        <div class="carousel-inner relative h-72 sm:h-96">
          <img src="<%= listing.image.url %>" class="carousel-img active h-full w-full object-cover" alt="<%= listing.title %>" />
          <% if(listing.images && listing.images.length > 0) { listing.images.forEach((img, index) => { %>
          <img src="<%= img.url %>" class="carousel-img h-full w-full object-cover" alt="<%= listing.title %> <%= index + 2 %>" />
          <% }) } %>
        </div>
        <div class="carousel-dots absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1"><span class="dot active h-2 w-2 rounded-full bg-white" data-index="0"></span><% if(listing.images && listing.images.length > 0) { listing.images.forEach((img, index) => { %><span class="dot h-2 w-2 rounded-full bg-white/60" data-index="<%= index + 1 %>"></span><% }) } %></div>
        <div class="carousel-controls pointer-events-none absolute inset-0 flex items-center justify-between px-2"><button class="carousel-control prev pointer-events-auto rounded-full bg-white/90 px-2 py-1"><i class="fas fa-chevron-left"></i></button><button class="carousel-control next pointer-events-auto rounded-full bg-white/90 px-2 py-1"><i class="fas fa-chevron-right"></i></button></div>
        <% if(currentUser) { %><button class="favorite-btn <%= isFavorite ? 'active' : '' %> absolute right-3 top-3 rounded-full bg-white/90 p-2" data-listing-id="<%= listing._id %>"><i class="<%= isFavorite ? 'fas' : 'far' %> fa-heart text-rose-600"></i></button><% } else { %><a href="/login" class="favorite-btn absolute right-3 top-3 rounded-full bg-white/90 p-2"><i class="far fa-heart text-rose-600"></i></a><% } %>
      </div>

      <article class="rounded-2xl bg-white p-6 shadow-soft">
        <div class="mb-4 flex items-center gap-3">
          <img src="<%= listing.owner.image.url || 'https://cdn.pixabay.com/photo/2018/11/13/22/01/avatar-3814081_1280.png' %>" alt="Owner" class="h-11 w-11 rounded-full object-cover" />
          <h3 class="text-lg font-semibold">Hosted by <%= listing.owner.username %></h3>
        </div>
        <p class="text-slate-700"><%= listing.description %></p>

        <div class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
          <div class="rounded-xl border border-slate-200 p-3"><span class="font-semibold">Room Type:</span> <%= listing.roomType || 'N/A' %></div>
          <div class="rounded-xl border border-slate-200 p-3"><span class="font-semibold">Furnishing:</span> <%= listing.furnished || 'N/A' %></div>
          <div class="rounded-xl border border-slate-200 p-3"><span class="font-semibold">Gender Preference:</span> <%= listing.genderPreference || 'Any' %></div>
          <div class="rounded-xl border border-slate-200 p-3"><span class="font-semibold">Tenants:</span> <%= listing.preferredTenants || 'Any' %></div>
        </div>
      </article>

      <section class="rounded-2xl bg-white p-6 shadow-soft">
        <h3 class="mb-4 text-lg font-bold">Reviews</h3>
        <% if(currentUser) { %>
        <form method="post" action="/listings/<%= listing._id %>/reviews" class="needs-validation space-y-3" novalidate>
          <label class="block text-sm font-semibold">Your Rating <span class="rating-value text-amber-600">5 <i class="fas fa-star"></i></span></label>
          <input id="rating" type="range" min="1" max="5" name="review[rating]" value="5" class="w-full" />
          <textarea name="review[comment]" rows="3" required placeholder="Write your experience" class="w-full rounded-xl border border-slate-300 px-4 py-2.5"></textarea>
          <button class="rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-700">Add Review</button>
        </form>
        <% } %>

        <div class="mt-6 space-y-3">
          <% listing.reviews.forEach(review => { %>
          <article class="rounded-xl border border-slate-200 p-4">
            <div class="flex items-center justify-between"><p class="text-sm font-semibold"><%= review.author.username %></p><span class="text-xs text-amber-600"><i class="fas fa-star"></i> <%= review.rating %></span></div>
            <p class="mt-2 text-sm text-slate-600"><%= review.comment %></p>
            <% if(currentUser && String(review.author._id) === String(currentUser._id)) { %>
            <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-3">
              <button class="btn-delete rounded-lg border border-rose-200 px-3 py-1 text-xs font-semibold text-rose-700" data-item-type="review">Delete</button>
            </form>
            <% } %>
          </article>
          <% }) %>
        </div>
      </section>
    </div>

    <aside class="space-y-4">
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <p class="listing-price text-2xl font-bold text-slate-900"><strong>?<%= listing.price.toLocaleString("en-IN") %></strong> <span class="text-sm font-medium text-slate-500">/ month</span></p>
        <p class="mt-1 text-sm text-slate-600"><%= listing.immediateAvailability ? 'Immediate Availability' : 'Available Soon' %></p>
        <p class="mt-3 text-sm text-slate-600">Security Deposit: ?<%= (listing.securityDeposit || 0).toLocaleString("en-IN") %></p>
        <p class="mt-1 text-sm text-slate-600">Min Stay: <%= listing.minStayMonths || 1 %> months</p>
      </div>

      <% if(currentUser && String(currentUser._id) === String(listing.owner._id)) { %>
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500">Owner Actions</h4>
        <div class="flex gap-2">
          <a href="/listings/<%= listing._id %>/edit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold">Edit</a>
          <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Delete this listing?');">
            <button class="btn-delete rounded-xl border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-700" data-item-type="listing">Delete</button>
          </form>
        </div>
      </div>
      <% } %>
    </aside>
  </div>
</section>
