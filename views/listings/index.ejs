<% layout("/layouts/boilerplate") %>
<section class="space-y-6">
  <div class="rounded-2xl bg-white p-4 shadow-soft">
    <div class="flex flex-wrap items-center gap-2">
      <button class="filter-btn active rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="all"><i class="fas fa-bed mr-1"></i><span>All Rooms</span></button>
      <% if (currentUser) { %><button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="favorites"><i class="fas fa-heart mr-1"></i><span>My Favorites</span></button><% } %>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="single"><i class="fas fa-user mr-1"></i><span>Single</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="shared"><i class="fas fa-users mr-1"></i><span>Shared</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="furnished"><i class="fas fa-couch mr-1"></i><span>Furnished</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="students"><i class="fas fa-graduation-cap mr-1"></i><span>For Students</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="professionals"><i class="fas fa-briefcase mr-1"></i><span>For Professionals</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="any-gender"><i class="fas fa-venus-mars mr-1"></i><span>Any Gender</span></button>
      <button class="filter-btn rounded-full border border-slate-300 px-4 py-2 text-sm font-medium" data-filter="immediate"><i class="fas fa-calendar-check mr-1"></i><span>Immediate</span></button>
      <button id="advanced-filters-btn" class="ml-auto rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white">More Filters</button>
    </div>
  </div>

  <div id="advanced-filters-modal" class="advanced-filters-modal fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4">
    <div class="advanced-filters-content w-full max-w-2xl rounded-2xl bg-white p-6 shadow-soft">
      <div class="mb-4 flex items-center justify-between"><h3 class="text-lg font-bold">Advanced Filters</h3><button class="close-modal-btn rounded-lg border px-3 py-1">×</button></div>
      <form id="advanced-filter-form" class="space-y-4 text-sm">
        <div class="grid gap-2 sm:grid-cols-3">
          <label><input type="checkbox" name="roomType" value="single" class="mr-2" />Single</label>
          <label><input type="checkbox" name="roomType" value="shared" class="mr-2" />Shared</label>
          <label><input type="checkbox" name="roomType" value="studio" class="mr-2" />Studio</label>
        </div>
        <div class="grid gap-2 sm:grid-cols-3">
          <label><input type="checkbox" name="furnished" value="furnished" class="mr-2" />Furnished</label>
          <label><input type="checkbox" name="furnished" value="unfurnished" class="mr-2" />Unfurnished</label>
          <label><input type="checkbox" name="furnished" value="semifurnished" class="mr-2" />Semi-furnished</label>
        </div>
        <div class="grid gap-2 sm:grid-cols-3">
          <label><input type="checkbox" name="gender" value="male" class="mr-2" />Male</label>
          <label><input type="checkbox" name="gender" value="female" class="mr-2" />Female</label>
          <label><input type="checkbox" name="gender" value="any" class="mr-2" />Any</label>
        </div>
        <div class="grid gap-2 sm:grid-cols-3">
          <input type="range" id="min-price" min="1000" max="50000" step="500" value="1000" />
          <input type="range" id="max-price" min="1000" max="50000" step="500" value="50000" />
          <div class="grid grid-cols-2 gap-2"><input id="min-price-input" type="number" value="1000" class="rounded-lg border px-2 py-1" /><input id="max-price-input" type="number" value="50000" class="rounded-lg border px-2 py-1" /></div>
        </div>
        <div class="grid gap-2 sm:grid-cols-3">
          <select name="location" class="rounded-lg border px-3 py-2"><option value="">All Locations</option><option value="central">Central Area</option><option value="north">North Area</option><option value="south">South Area</option><option value="east">East Area</option><option value="west">West Area</option></select>
          <label><input type="radio" name="availability" value="immediate" class="mr-2" />Immediate</label>
          <label><input type="radio" name="availability" value="any" checked class="mr-2" />Any</label>
        </div>
        <div id="specific-date-container" class="hidden"><input type="date" id="available-from" name="availableFrom" class="rounded-lg border px-3 py-2" /></div>
        <div class="grid gap-2 sm:grid-cols-3">
          <label><input type="checkbox" name="amenities" value="wifi" class="mr-2" />WiFi</label>
          <label><input type="checkbox" name="amenities" value="ac" class="mr-2" />AC</label>
          <label><input type="checkbox" name="amenities" value="parking" class="mr-2" />Parking</label>
        </div>
        <div class="flex justify-end gap-2"><button type="button" class="reset-btn rounded-lg border px-4 py-2">Reset</button><button type="submit" class="apply-btn rounded-lg bg-rose-600 px-4 py-2 font-semibold text-white">Apply</button></div>
      </form>
    </div>
  </div>

  <div class="listings-grid grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
    <% for(let listing of allListings) { %>
    <% let avgRating = 3; if (listing.reviews && listing.reviews.length > 0) { const totalRating = listing.reviews.reduce((sum, review) => sum + (review.rating || 0), 0); avgRating = totalRating / listing.reviews.length; } %>
    <div class="listing-col" data-listing-id="<%= listing._id %>" data-is-favorite="<%= listing.isFavorite || false %>" data-room-type="<%= listing.roomType || 'single' %>" data-furnished="<%= listing.furnished || 'furnished' %>" data-gender="<%= listing.genderPreference || 'any' %>" data-tenants="<%= listing.preferredTenants || 'any' %>" data-price="<%= listing.price %>" data-location="<%= listing.location || '' %>" data-availability="<%= listing.immediateAvailability ? 'immediate' : 'later' %>" data-available-from="<%= listing.availableFrom || '' %>">
      <a href="/listings/<%= listing._id %>" class="block h-full">
        <article class="listing-card h-full overflow-hidden rounded-2xl bg-white shadow-soft transition hover:-translate-y-1">
          <div class="image-carousel relative h-56">
            <div class="carousel-inner h-full">
              <img src="<%= listing.image.url %>" class="carousel-img active h-56 w-full object-cover" alt="<%= listing.title %>" />
              <% if(listing.images && listing.images.length > 0) { listing.images.forEach((img) => { %>
              <img src="<%= img.url %>" class="carousel-img h-56 w-full object-cover" alt="<%= listing.title %>" />
              <% }) } %>
            </div>
            <div class="carousel-dots absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1">
              <span class="dot active h-2 w-2 rounded-full bg-white/90" data-index="0"></span>
              <% if(listing.images && listing.images.length > 0) { listing.images.forEach((img, index) => { %><span class="dot h-2 w-2 rounded-full bg-white/50" data-index="<%= index + 1 %>"></span><% }) } %>
            </div>
            <div class="carousel-controls pointer-events-none absolute inset-0 flex items-center justify-between px-2">
              <button class="carousel-control prev pointer-events-auto rounded-full bg-white/90 px-2 py-1"><i class="fas fa-chevron-left"></i></button>
              <button class="carousel-control next pointer-events-auto rounded-full bg-white/90 px-2 py-1"><i class="fas fa-chevron-right"></i></button>
            </div>
            <button class="favorite-btn <%= listing.isFavorite ? 'active' : '' %> absolute right-3 top-3 rounded-full bg-white/90 p-2" aria-label="Toggle favorites" data-listing-id="<%= listing._id %>"><i class="<%= listing.isFavorite ? 'fas' : 'far' %> fa-heart text-rose-600"></i></button>
          </div>
          <div class="p-4">
            <div class="mb-2 flex items-start justify-between gap-3">
              <h3 class="line-clamp-1 text-base font-semibold"><%= listing.title %></h3>
              <div class="listing-rating text-sm text-amber-500"><i class="fas fa-star"></i> <span><%= avgRating.toFixed(1) %></span></div>
            </div>
            <p class="text-sm text-slate-500"><%= listing.location || 'Great location' %></p>
            <p class="listing-price mt-3 text-sm"><strong>?<%= listing.price.toLocaleString("en-IN") %></strong> / month</p>
            <p class="mt-1 text-xs text-slate-500"><%= listing.immediateAvailability ? 'Available Now' : 'Available Soon' %></p>
            <div class="mt-3 flex items-center gap-2 text-xs text-slate-500">
              <img src="<%= listing.owner && listing.owner.image && listing.owner.image.url ? listing.owner.image.url : 'https://cdn.pixabay.com/photo/2018/11/13/22/01/avatar-3814081_1280.png' %>" class="h-7 w-7 rounded-full object-cover" alt="Host" />
              <span>Hosted by <%= listing.owner && listing.owner.username ? listing.owner.username : 'User' %></span>
            </div>
          </div>
        </article>
      </a>
    </div>
    <% } %>
  </div>
</section>

<script src="/init/data.js"></script>
<script src="/js/room-filters.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.filter-btn[data-filter]');
    const listingsGrid = document.querySelector('.listings-grid');
    window.listings = Array.from(document.querySelectorAll('.listing-col'));
    const listings = window.listings;
    let activeFilter = new URLSearchParams(window.location.search).get('filter') || 'all';
    function getBooleanAttribute(element, attribute) { const value = element.getAttribute(attribute); return value === 'true' || value === ''; }
    function updateListingsDisplay() {
      let visibleCount = 0;
      listings.forEach(listing => {
        const isFavorite = getBooleanAttribute(listing, 'data-is-favorite');
        if (activeFilter === 'favorites') { listing.style.display = isFavorite ? 'block' : 'none'; if (isFavorite) visibleCount++; }
        else { listing.style.display = 'block'; visibleCount++; }
      });
      if (activeFilter === 'favorites' && visibleCount === 0 && listingsGrid && !document.querySelector('.no-favorites-message')) {
        const noResults = document.createElement('div');
        noResults.className = 'no-favorites-message rounded-xl border border-slate-200 bg-white p-8 text-center text-slate-600';
        noResults.innerHTML = '<i class="fas fa-heart-broken mb-3 text-3xl text-rose-400"></i><h4 class="font-semibold">No favorite listings yet</h4>';
        listingsGrid.appendChild(noResults);
      } else { const existingMessage = document.querySelector('.no-favorites-message'); if (existingMessage) existingMessage.remove(); }
    }
    document.addEventListener('filterUpdated', updateListingsDisplay);
    filterButtons.forEach(button => button.addEventListener('click', function() {
      activeFilter = this.getAttribute('data-filter');
      filterButtons.forEach(btn => btn.classList.remove('active')); this.classList.add('active');
      const url = new URL(window.location); if (activeFilter === 'all') url.searchParams.delete('filter'); else url.searchParams.set('filter', activeFilter);
      window.history.pushState({}, '', url); updateListingsDisplay();
    }));
    if (new URLSearchParams(window.location.search).get('filter') === 'favorites') {
      const favoritesBtn = document.querySelector('.filter-btn[data-filter="favorites"]'); if (favoritesBtn) favoritesBtn.click();
    }
  });
</script>
