<% layout("/layouts/boilerplateHome") %>
<section class="overflow-hidden rounded-3xl bg-gradient-to-br from-rose-50 via-white to-sky-50 p-8 shadow-soft sm:p-12">
  <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-rose-700">Find Your Perfect Stay</p>
      <h1 class="mt-4 text-4xl font-bold leading-tight text-slate-900 sm:text-5xl">Welcome to SKN_Accomodation</h1>
      <p class="mt-4 text-lg text-slate-600">Discover rooms, shared spaces, and premium homes that fit your lifestyle and budget.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/listings" class="rounded-xl bg-rose-600 px-5 py-3 text-sm font-semibold text-white hover:bg-rose-700">Browse Listings</a>
        <% if(!currentUser) { %>
        <a href="/login" class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-white">Log In</a>
        <a href="/signup" class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-white">Sign Up</a>
        <% } %>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <img class="h-40 w-full rounded-2xl object-cover sm:h-48" src="https://images.unsplash.com/photo-1482192505345-5655af888cc4?q=80&w=1200&auto=format&fit=crop" alt="Room" />
      <img class="h-40 w-full rounded-2xl object-cover sm:h-48" src="https://a0.muscache.com/im/pictures/81dca5d6-5a86-49bc-8eca-4a8610a07d27.jpg?im_w=1200" alt="Listing" />
      <img class="h-40 w-full rounded-2xl object-cover sm:h-48" src="https://a0.muscache.com/im/ml/photo_enhancement/pictures/miso/Hosting-990107274204637127/original/67921aa9-44fe-4913-ab38-d486f3f30ae0.jpeg?im_w=1200" alt="Hostel" />
      <img class="h-40 w-full rounded-2xl object-cover sm:h-48" src="https://a0.muscache.com/im/ml/photo_enhancement/pictures/miso/Hosting-35746251/original/3953eeb5-0e49-426b-8967-f0236cc64cf3.jpeg?im_w=1200" alt="Apartment" />
    </div>
  </div>
</section>

<section class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  <article class="rounded-2xl bg-white p-6 shadow-soft">
    <i class="fas fa-map-marker-alt text-rose-600"></i>
    <h3 class="mt-3 text-lg font-semibold">Great Locations</h3>
    <p class="mt-2 text-sm text-slate-600">Prime student and professional areas across major cities.</p>
  </article>
  <article class="rounded-2xl bg-white p-6 shadow-soft">
    <i class="fas fa-shield-alt text-rose-600"></i>
    <h3 class="mt-3 text-lg font-semibold">Trusted Platform</h3>
    <p class="mt-2 text-sm text-slate-600">Verified profiles, reviews, and safer booking communication.</p>
  </article>
  <article class="rounded-2xl bg-white p-6 shadow-soft">
    <i class="fas fa-heart text-rose-600"></i>
    <h3 class="mt-3 text-lg font-semibold">Better Experience</h3>
    <p class="mt-2 text-sm text-slate-600">Shortlist favorites and manage your housing journey seamlessly.</p>
  </article>
</section>
